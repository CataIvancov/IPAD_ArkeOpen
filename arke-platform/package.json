{
  "name": "arke-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web-app",
    "web-admin",
    "server/arkeoserver"
  ],
  "scripts": {
    "dev:web-app:arkeopen": "npm --prefix ../arkeopen-upstream/web-app run dev:arkeopen",
    "dev:web-app:arkeogis": "npm --prefix ../arkeopen-upstream/web-app run dev:arkeogis",
    "build:web-app:arkeopen": "npm --prefix ../arkeopen-upstream/web-app run build:arkeopen",
    "build:web-app:arkeogis": "npm --prefix ../arkeopen-upstream/web-app run build:arkeogis",
    "dev:web-admin:arkeopen": "npm --prefix ../arkeopen-upstream/web-admin start",
    "dev:web-admin:arkeogis": "npm --prefix ../arkeopen-upstream/web-admin start",
    "build:web-admin:arkeopen": "npm --prefix ../arkeopen-upstream/web-admin run build",
    "build:web-admin:arkeogis": "npm --prefix ../arkeopen-upstream/web-admin run build",
    "server:up": "docker compose --env-file ../arkeopen-upstream/server/.env -f ../arkeopen-upstream/server/docker-compose.yaml up -d",
    "server:down": "docker compose --env-file ../arkeopen-upstream/server/.env -f ../arkeopen-upstream/server/docker-compose.yaml down",
    "server:logs": "docker compose --env-file ../arkeopen-upstream/server/.env -f ../arkeopen-upstream/server/docker-compose.yaml logs -f",
    "doctor:upstream-data": "sh ./scripts/check-upstream-data.sh",
    "import:public-seeds": "sh ./scripts/import-public-arkeogis-seeds.sh",
    "align:arkeopen-thesauri": "python3 ./scripts/align-nakala-thesaurus.py all",
    "align:mobilier-thesaurus": "python3 ./scripts/align-nakala-thesaurus.py mobilier",
    "align:paysage-thesaurus": "python3 ./scripts/align-nakala-thesaurus.py paysage",
    "align:production-thesaurus": "python3 ./scripts/align-nakala-thesaurus.py production",
    "align:immobilier-thesaurus": "python3 ./scripts/align-nakala-thesaurus.py immobilier",
    "align:analyses-thesaurus": "python3 ./scripts/align-nakala-thesaurus.py analyses",
    "import:quaternary-chronology-en": "python3 ./scripts/import-quaternary-chronology-en.py",
    "import:indonesia-prehistory-protohistory-chronology": "python3 ./scripts/import-indonesia-prehistory-protohistory-chronology.py",
    "deactivate-other-chronologies": "python3 ./scripts/deactivate-other-chronologies.py",
    "import:bibracte-map-source": "python3 ./scripts/import-bibracte-map-source.py",
    "import:lorraine-medieval-sites": "python3 ./scripts/import-lorraine-medieval-sites.py",
    "import:enserune-inscriptions": "python3 ./scripts/import-enserune-inscriptions.py",
    "import:airtable-site-only-v4": "python3 ./scripts/import-airtable-site-only-v4.py",
    "drive:inventory": "python3 ./scripts/google-drive-inventory.py",
    "drive:download-pdfs": "python3 ./scripts/google-drive-download-pdfs.py",
    "drive:extract-pdf-text": "python3 ./scripts/extract-pdf-text.py",
    "drive:extract-chronology-candidates": "python3 ./scripts/extract-chronology-candidates.py",
    "drive:extract-technoculture-candidates": "python3 ./scripts/extract-technoculture-candidates.py",
    "drive:build-indonesian-technocultures": "python3 ./scripts/build-indonesian-technoculture-candidates.py",
    "drive:extract-site-geolocations": "python3 ./scripts/extract-site-geolocation-candidates.py",
    "drive:build-arkeogis-sites": "python3 ./scripts/build-drive-sites-arkeogis-csv.py",
    "drive:build-site-images": "python3 ./scripts/build-drive-site-images.py",
    "convert:airtable-to-arkeogis": "python3 ./scripts/convert-airtable-to-arkeogis-template.py",
    "convert:airtable-to-arkeogis:v2": "python3 ./scripts/convert-airtable-to-arkeogis-template-v2.py",
    "convert:airtable-to-arkeogis:v3-site-only": "python3 ./scripts/convert-airtable-to-arkeogis-template-v3-site-only.py",
    "convert:airtable-to-arkeogis:v4-site-only": "python3 ./scripts/convert-airtable-to-arkeogis-template-v4-site-only.py"
  }
}
