  _:genid-cf911f50088f4ceeab2aef5ab9c14349-t9728 a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """SELECT ?value WHERE {
  $subject <http://www.cidoc-crm.org/cidoc-crm/P107i_is_current_or_former_member_of> ?structure . 
  ?structure rdfs:label ?value
}""" .
  
  _:genid-cf911f50088f4ceeab2aef5ab9c14349-t9729 a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """SELECT ?value ?label WHERE {
  ?value a crm:E74_Group ;
    rdfs:label ?label .
  FILTER REGEX(STR(?label), \"?token\")
} LIMIT 10""" .
  
  _:genid-cf911f50088f4ceeab2aef5ab9c14349-t9730 a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """INSERT { $subject <http://www.cidoc-crm.org/cidoc-crm/P107i_is_current_or_former_member_of> ?structure.
