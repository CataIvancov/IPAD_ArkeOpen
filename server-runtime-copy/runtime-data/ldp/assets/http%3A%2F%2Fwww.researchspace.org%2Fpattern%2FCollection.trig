    <http://www.w3.org/2000/01/rdf-schema#label> "Collection"@en;
    <http://www.researchspace.org/resource/system/fields/askPattern> _:genid-0242c644ce844ce096c1f79c20687b5a-l5q0vk;
    <http://www.researchspace.org/resource/system/fields/insertPattern> _:genid-0242c644ce844ce096c1f79c20687b5a-efgk4;
    <http://www.researchspace.org/resource/system/fields/autosuggestionPattern> _:genid-0242c644ce844ce096c1f79c20687b5a-017rll;
    <http://www.researchspace.org/resource/system/fields/xsdDatatype> <http://www.w3.org/2001/XMLSchema#anyURI>;
    <http://www.researchspace.org/resource/system/fields/valueSetPattern> _:genid-0242c644ce844ce096c1f79c20687b5a-ipsgk;
    <http://www.researchspace.org/resource/system/fields/domain> <crm:E78_Collection>;
    <http://www.researchspace.org/resource/system/fields/range> <http://www.cidoc-crm.org/cidoc-crm/E19_Physical_Object>;
    <http://www.w3.org/2000/01/rdf-schema#comment> "Knowledge Pattern for archaeological and scientific collections such as ROCEEH Assemblages and FaunalAssemblages, based on CIDOC CRM class E78_Collection.";
    <http://www.researchspace.org/resource/system/fields/deletePattern> _:genid-0242c644ce844ce096c1f79c20687b5a-cqm3lk;
    <http://www.researchspace.org/resource/system/fields/category> <http://www.researchspace.org/resource/system/category/curated_collection>;
    <http://www.w3.org/ns/prov#wasAttributedTo> <http://www.researchspace.org/resource/user/admin>;
    <http://www.w3.org/ns/prov#generatedAtTime> "2025-10-10T06:04:19.588Z"^^<http://www.w3.org/2001/XMLSchema#dateTime> .
  
  _:genid-0242c644ce844ce096c1f79c20687b5a-80s0ms a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """SELECT DISTINCT ?value ?label WHERE {
  $subject crm:P46_is_composed_of ?value .
  ?value a crm:E19_Physical_Object .
  OPTIONAL {
    ?value crm:P1_is_identified_by ?appellation .
    ?appellation a crm:E41_Appellation .
    ?appellation crm:P190_has_symbolic_content ?label .
  }
}""" .
  
  _:genid-0242c644ce844ce096c1f79c20687b5a-l5q0vk a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> "ASK { $subject a crm:E78_Collection . }" .
  
  _:genid-0242c644ce844ce096c1f79c20687b5a-017rll a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """SELECT DISTINCT ?value ?label WHERE {
  ?value a crm:E19_Physical_Object .
  OPTIONAL {
    ?value crm:P1_is_identified_by ?appellation .
    ?appellation a crm:E41_Appellation .
    ?appellation crm:P190_has_symbolic_content ?label .
  }
  FILTER REGEX(LCASE(STR(?label)), \"?token\", \"i\")
} ORDER BY ASC(?label)
LIMIT 10""" .
  
  _:genid-0242c644ce844ce096c1f79c20687b5a-ipsgk a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """SELECT DISTINCT ?value ?label WHERE {
  ?value a crm:E19_Physical_Object .
  OPTIONAL {
    ?value crm:P1_is_identified_by ?appellation .
    ?appellation a crm:E41_Appellation .
    ?appellation crm:P190_has_symbolic_content ?label .
  }
} ORDER BY ASC(LCASE(STR(?label)))""" .
  
  _:genid-0242c644ce844ce096c1f79c20687b5a-efgk4 a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """INSERT { 
  $subject crm:P46_is_composed_of $value .
  $value crm:P46i_forms_part_of $subject .
} WHERE {}""" .
  
  _:genid-0242c644ce844ce096c1f79c20687b5a-cqm3lk a <http://spinrdf.org/sp#Query>;
    <http://spinrdf.org/sp#text> """DELETE {
  $subject crm:P46_is_composed_of $value .
  $value crm:P46i_forms_part_of $subject .
} WHERE {
  $subject crm:P46_is_composed_of $value .
}""" .
  
  <http://www.researchspace.org/resource/system/fieldDefinitionContainer> <http://www.w3.org/ns/ldp#contains>
      <http://www.researchspace.org/pattern/Collection> .
}
